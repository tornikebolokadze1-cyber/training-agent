# ======================================================================
# Training Agent — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ======================================================================

# --- Zoom (Server-to-Server OAuth) ---
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=         # Zoom Event Notification secret token (for CRC validation)
ZOOM_GROUP1_MEETING_ID=
ZOOM_GROUP2_MEETING_ID=

# --- Google OAuth ---
# Local: path to credentials file
GOOGLE_CREDENTIALS_PATH=./credentials.json
# Railway: base64-encode the files instead
# GOOGLE_CREDENTIALS_JSON_B64=   # base64 -i credentials.json
# GOOGLE_TOKEN_JSON_B64=         # base64 -i token.json

# --- Google Drive folder IDs ---
DRIVE_GROUP1_FOLDER_ID=
DRIVE_GROUP2_FOLDER_ID=
DRIVE_GROUP1_ANALYSIS_FOLDER_ID=
DRIVE_GROUP2_ANALYSIS_FOLDER_ID=

# --- Gemini AI ---
GEMINI_API_KEY=
GEMINI_API_KEY_PAID=              # Optional: separate paid key for embeddings

# --- Anthropic (Claude Opus — assistant reasoning) ---
ANTHROPIC_API_KEY=

# --- Pinecone (vector DB for RAG) ---
PINECONE_API_KEY=

# --- WhatsApp via Green API ---
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=
WHATSAPP_TORNIKE_PHONE=           # e.g. 995599123456
WHATSAPP_GROUP1_ID=               # e.g. 120363XXX@g.us
WHATSAPP_GROUP2_ID=

# --- Gmail (email notifications) ---
# GOOGLE_GMAIL_TOKEN_JSON_B64=    # base64 -i token_gmail.json

# --- Email Fallback (for when WhatsApp is down) ---
GMAIL_SENDER_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
OPERATOR_EMAIL=operator@example.com

# --- Webhook security ---
WEBHOOK_SECRET=                   # Shared secret for n8n <-> Python auth

# --- n8n callback ---
N8N_CALLBACK_URL=                 # e.g. https://your-n8n.app.n8n.cloud/webhook/xxx

# --- Paperclip bridge ---
# Separate secret for Paperclip -> /paperclip/task so it can be rotated
# independently of WEBHOOK_SECRET. Leave blank to reuse WEBHOOK_SECRET.
PAPERCLIP_WEBHOOK_SECRET=generate-a-random-32-char-string
# Base URL of the local Paperclip API (used to post comments and patch issue status).
PAPERCLIP_API_BASE=http://127.0.0.1:3100
PAPERCLIP_URL=http://localhost:3100
PAPERCLIP_AGENT_ID=  # fill with the Training Operations Lead agent ID after Paperclip hire
PAPERCLIP_COMPANY_ID=21679925-5983-405b-bb4d-fb6f05c3159a

# --- Server ---
SERVER_HOST=127.0.0.1             # Use 0.0.0.0 for Docker/Railway
SERVER_PORT=5001
# SERVER_PUBLIC_URL=              # e.g. https://your-app.up.railway.app

# --- Lecture Schedule ---
# Comma-separated ISO dates to skip (holidays, cancellations)
# EXCLUDED_DATES=2026-04-01,2026-04-15

# --- Course lifecycle ---
# Global kill-switch. Set to 1 to force ALL lecture cron jobs off, regardless
# of per-group flags. Usually you want the per-group `course_completed` field
# in `tools/core/config.py` (or `GROUP{N}_COURSE_COMPLETED` for env-driven
# groups) instead — the scheduler also flips off automatically when every
# configured group has `course_completed=True`. This env var is the override
# for emergencies (e.g. WhatsApp outage where you need every reminder muted).
COURSE_COMPLETED=0

# --- Optional additional groups (Course #2 onwards) ---
# Each new group is enabled by setting the pair below; missing pair = no group.
# See docs/operations/runbooks/add-new-course.md for the full onboarding flow.
#
# DRIVE_GROUP3_FOLDER_ID=          # required: Drive parent folder ID
# DRIVE_GROUP3_ANALYSIS_FOLDER_ID= # private folder for gap/deep analysis
# WHATSAPP_GROUP3_ID=              # required: 120363XXX@g.us
# ZOOM_GROUP3_MEETING_ID=          # optional: shared Zoom room is fine
# GROUP3_NAME=მაისის ჯგუფი #3      # display name shown in WhatsApp/Drive
# GROUP3_FOLDER_NAME=AI კურსი (მაისის ჯგუფი #3. 2026)
# GROUP3_MEETING_DAYS=2,5          # comma-separated weekday ints (Mon=0)
# GROUP3_START_DATE=2026-05-13     # ISO date of first lecture
# GROUP3_COURSE_COMPLETED=0        # flip to 1 when this group finishes
#
# Pattern repeats for GROUP4, GROUP5, … up to GROUP9.

# --- Cost Control ---
LECTURE_COST_LIMIT_USD=5.0            # Max spend per lecture ($2 typical, $5 allows retries)
# GEMINI_FALLBACK_TRANSCRIPTION_MODEL=gemini-2.5-pro

# --- Georgian writing fallback ---
# Set to 1 to route Georgian writing (summary/gap/deep) through Claude instead
# of Gemini 3.1 Pro Preview. Adds ~$0.25 per lecture, but Claude has no quota
# limits in our setup whereas Gemini Pro returns 429 unpredictably. Strongly
# recommended for production. See commit 43196dc for implementation.
USE_CLAUDE_FOR_GEORGIAN_WRITING=1

# --- Railway (auto-set by Railway, do NOT set manually) ---
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
# PORT=                           # Railway injects this

# --- Mem0 persistent memory (WhatsApp assistant) ---
# Qdrant Cloud — vector store for personal memory (free tier: 1GB)
# Sign up: https://cloud.qdrant.io
QDRANT_URL=                       # e.g. https://abc123.us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=

# Neo4j AuraDB — graph store for relational memory (free tier available)
# Sign up: https://console.neo4j.io
NEO4J_URL=                        # e.g. neo4j+s://abc123.databases.neo4j.io
NEO4J_USERNAME=                   # e.g. neo4j
NEO4J_PASSWORD=

# --- Attendees (Railway only) ---
# ATTENDEES_JSON_B64=             # base64 -i attendees.json
