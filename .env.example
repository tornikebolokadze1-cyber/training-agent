# ======================================================================
# Training Agent — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ======================================================================

# --- Zoom (Server-to-Server OAuth) ---
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=         # Zoom Event Notification secret token (for CRC validation)
ZOOM_GROUP1_MEETING_ID=
ZOOM_GROUP2_MEETING_ID=

# --- Google OAuth ---
# Local: path to credentials file
GOOGLE_CREDENTIALS_PATH=./credentials.json
# Railway: base64-encode the files instead
# GOOGLE_CREDENTIALS_JSON_B64=   # base64 -i credentials.json
# GOOGLE_TOKEN_JSON_B64=         # base64 -i token.json

# --- Google Drive folder IDs ---
DRIVE_GROUP1_FOLDER_ID=
DRIVE_GROUP2_FOLDER_ID=
DRIVE_GROUP1_ANALYSIS_FOLDER_ID=
DRIVE_GROUP2_ANALYSIS_FOLDER_ID=

# --- Gemini AI ---
GEMINI_API_KEY=
GEMINI_API_KEY_PAID=              # Optional: separate paid key for embeddings

# --- Anthropic (Claude Opus — assistant reasoning) ---
ANTHROPIC_API_KEY=

# --- Pinecone (vector DB for RAG) ---
PINECONE_API_KEY=

# --- WhatsApp via Green API ---
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=
WHATSAPP_TORNIKE_PHONE=           # e.g. 995599123456
WHATSAPP_GROUP1_ID=               # e.g. 120363XXX@g.us
WHATSAPP_GROUP2_ID=

# --- Gmail (email notifications) ---
# GOOGLE_GMAIL_TOKEN_JSON_B64=    # base64 -i token_gmail.json

# --- Email Fallback (for when WhatsApp is down) ---
GMAIL_SENDER_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
OPERATOR_EMAIL=operator@example.com

# --- Webhook security ---
WEBHOOK_SECRET=                   # Shared secret for n8n <-> Python auth

# --- n8n callback ---
N8N_CALLBACK_URL=                 # e.g. https://your-n8n.app.n8n.cloud/webhook/xxx

# --- Server ---
SERVER_HOST=127.0.0.1             # Use 0.0.0.0 for Docker/Railway
SERVER_PORT=5001
# SERVER_PUBLIC_URL=              # e.g. https://your-app.up.railway.app

# --- Lecture Schedule ---
# Comma-separated ISO dates to skip (holidays, cancellations)
# EXCLUDED_DATES=2026-04-01,2026-04-15

# --- Cost Control ---
LECTURE_COST_LIMIT_USD=5.0            # Max spend per lecture ($2 typical, $5 allows retries)
# GEMINI_FALLBACK_TRANSCRIPTION_MODEL=gemini-2.5-pro

# --- Railway (auto-set by Railway, do NOT set manually) ---
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
# PORT=                           # Railway injects this

# --- Mem0 persistent memory (WhatsApp assistant) ---
# Qdrant Cloud — vector store for personal memory (free tier: 1GB)
# Sign up: https://cloud.qdrant.io
QDRANT_URL=                       # e.g. https://abc123.us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=

# Neo4j AuraDB — graph store for relational memory (free tier available)
# Sign up: https://console.neo4j.io
NEO4J_URL=                        # e.g. neo4j+s://abc123.databases.neo4j.io
NEO4J_USERNAME=                   # e.g. neo4j
NEO4J_PASSWORD=

# --- Attendees (Railway only) ---
# ATTENDEES_JSON_B64=             # base64 -i attendees.json
